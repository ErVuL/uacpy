# ---------------------------------------------------------------------------
# UACPY-specific
# ---------------------------------------------------------------------------

# OASES is not redistributable; install.sh downloads it on demand.
uacpy/third_party/oases/

# Compiled native binaries are generated by install.sh, never committed.
uacpy/bin/

# Example output (figures generated by running the examples)
uacpy/examples/output/

# In-tree Fortran/C build trees under third_party/
uacpy/third_party/mpiramS/obj/
uacpy/third_party/mpiramS/mod/
uacpy/third_party/bellhopcuda/build/
uacpy/third_party/bellhopcuda/bin/


# ---------------------------------------------------------------------------
# Fortran / C / C++ build artifacts
# (Acoustics-Toolbox and mpiramS build in-place inside their source dirs)
# ---------------------------------------------------------------------------
*.o
*.obj
*.mod
*.smod
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out


# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
dist/
wheels/
pip-wheel-metadata/
MANIFEST

# Test / coverage / type-check caches
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.cache/
.tox/
.nox/
.mypy_cache/
.pyre/
.ruff_cache/
.hypothesis/


# ---------------------------------------------------------------------------
# Editors / IDEs
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.nvim/
.ropeproject/


# ---------------------------------------------------------------------------
# Operating system
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini


# ---------------------------------------------------------------------------
# Temporary files produced by model runs
# (FileManager may create tmp dirs; Bellhop/Kraken leave .prt/.shd next to inputs
# when run outside FileManager's tmp dir)
# ---------------------------------------------------------------------------
*.prt
*.shd
*.ray
*.arr
*.grn
*.rts
*.flp.out
*.log
tmp_uacpy_*/
